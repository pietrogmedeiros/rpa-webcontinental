# ─── Pipedrive ────────────────────────────────────────
PIPEDRIVE_EMAIL=seu-email@empresa.com
PIPEDRIVE_PASSWORD=sua-senha-aqui
PIPEDRIVE_DOMAIN=nome-da-sua-empresa   # ex: webcontinental (parte da URL)
PIPEDRIVE_FILTER=[GALLANT] Leads criados - diários.

# ─── Google Drive ─────────────────────────────────────
GDRIVE_FOLDER_ID=1AbCdEfGhIjKlMnOpQrStUvWx   # ID da pasta no Drive

# Cole o JSON inteiro da service account como string (uma linha só):
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# OU informe o caminho do arquivo JSON montado no container:
# GOOGLE_SERVICE_ACCOUNT_FILE=/app/credentials/service_account.json

# ─── Agendamento ──────────────────────────────────────
RUN_HOUR=7
RUN_MINUTE=0
TZ=America/Sao_Paulo

# ─── Dev/Test ─────────────────────────────────────────
RUN_ON_START=false   # mude para true para rodar imediatamente ao subir
